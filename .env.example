# ============================================================
#  Super Code — переменные окружения
#  Скопируйте этот файл в .env и подставьте свои значения.
# ============================================================

# --- База данных PostgreSQL ---
# Локально или на хостинге (Neon, Supabase, Railway и т.п.)
DATABASE_URL="postgresql://user:password@localhost:5432/supercode?schema=public"

# --- Секрет для подписи сессий (JWT) ---
# Сгенерируйте длинную случайную строку, например командой:
#   openssl rand -base64 48
AUTH_SECRET="замените-на-длинную-случайную-строку"

# --- Bunny Stream (видео) ---
# Всё это берётся в панели bunny.net → Stream → ваша Video Library
BUNNY_STREAM_LIBRARY_ID="123456"
# API-ключ библиотеки (для загрузки видео из админки)
BUNNY_STREAM_API_KEY="ваш-api-ключ-библиотеки"
# Ключ токен-аутентификации (Security → Token Authentication Key)
BUNNY_STREAM_TOKEN_KEY="ваш-token-authentication-key"
# Хост воспроизведения, вида vz-xxxxx.b-cdn.net (Pull Zone)
BUNNY_STREAM_CDN_HOSTNAME="vz-xxxxxxxx.b-cdn.net"
# Хост встраиваемого плеера (обычно iframe.mediadelivery.net)
BUNNY_STREAM_EMBED_HOSTNAME="iframe.mediadelivery.net"

# --- Bunny Storage (файлы: чеки, аватарки, логотипы, видео-отзывы) ---
# Storage → Add Storage Zone, затем привяжите Pull Zone (CDN → Add Pull Zone,
# Origin Type: Storage Zone) — без неё файлы не будут доступны публично.
BUNNY_STORAGE_ZONE_NAME="ваша-storage-zone"
# FTP & API Access → Password этой Storage Zone
BUNNY_STORAGE_API_KEY="ваш-storage-api-ключ"
# Хост для загрузки — зависит от региона зоны (см. FTP & API Access)
BUNNY_STORAGE_HOSTNAME="storage.bunnycdn.com"
# Хост Pull Zone, привязанной к этой Storage Zone (вида xxxx.b-cdn.net)
BUNNY_STORAGE_CDN_HOSTNAME="xxxx.b-cdn.net"

# --- Базовый URL приложения (для ссылок в письмах и т.п.) ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Super AI (Gemini API) ---
# Ключ из Google AI Studio (aistudio.google.com/apikey)
GEMINI_API_KEY="ваш-gemini-api-ключ"

# --- Super AI fallback-провайдер (Groq, OpenAI-совместимый API) ---
# Используется автоматически, если Gemini вернул 503/429 после всех retry.
# Ключ из console.groq.com/keys
GROQ_API_KEY="ваш-groq-api-ключ"
